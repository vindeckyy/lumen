    "vue": "3.5.39",
    "vue-i18n": "11.4.6",
    "vue3-simple-icons": "16.10.0"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "2.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "serve": "14.2.6",
    "vite": "6.4.3",
    "vite-plugin-ejs": "2.0.0"
  }
}
